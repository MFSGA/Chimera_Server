{
  // Chimera_Server - All protocol/transport/security combination test config
  // Generated to exercise every valid inbound combo that currently validates

  "api": {
    "listen": "127.0.0.1:9090",
    "services": [
      "HandlerService",
      "LoggerService",
      "StatsService"
    ]
  },

  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "type": "field",
        "inboundTag": ["api-inbound"],
        "outboundTag": "api-out"
      }
    ]
  },

  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct-out"
    },
    {
      "protocol": "blackhole",
      "tag": "api-out"
    }
  ],

  "inbounds": [
    // ===== Non-TLS TCP =====
    {
      "tag": "socks-tcp-none",
      "protocol": "socks",
      "listen": "0.0.0.0",
      "port": 10000,
      "settings": {
        "auth": "noauth"
      }
    },
    {
      "tag": "vless-tcp-none",
      "protocol": "vless",
      "listen": "0.0.0.0",
      "port": 10002,
      "settings": {
        "clients": [
          {
            "id": "3ac9b383-75a1-431c-8184-106c80eb2273",
            "email": "test@vless-tcp-none",
            "flow": ""
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "none"
      }
    },
    {
      "tag": "trojan-tcp-none",
      "protocol": "trojan",
      "listen": "0.0.0.0",
      "port": 10005,
      "settings": {
        "clients": [
          {
            "password": "chimera-test-password",
            "email": "test@trojan-tcp-none"
          }
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "none"
      }
    },
    {
      "tag": "dokodemo-tcp-none",
      "protocol": "dokodemo-door",
      "listen": "0.0.0.0",
      "port": 10007,
      "settings": {
        "address": "8.8.8.8",
        "port": 53,
        "followRedirect": false
      },
      "streamSettings": {
        "network": "tcp",
        "security": "none"
      }
    },

    // ===== Non-TLS WebSocket =====
    {
      "tag": "socks-ws-none",
      "protocol": "socks",
      "listen": "0.0.0.0",
      "port": 10001,
      "settings": {
        "auth": "noauth"
      },
      "streamSettings": {
        "network": "ws",
        "security": "none",
        "wsSettings": {
          "host": "test.chimera.local",
          "path": "/socks"
        }
      }
    },
    {
      "tag": "vless-ws-none",
      "protocol": "vless",
      "listen": "0.0.0.0",
      "port": 10003,
      "settings": {
        "clients": [
          {
            "id": "3ac9b383-75a1-431c-8184-106c80eb2273",
            "email": "test@vless-ws-none",
            "flow": ""
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "ws",
        "security": "none",
        "wsSettings": {
          "host": "test.chimera.local",
          "path": "/vless"
        }
      }
    },
    {
      "tag": "trojan-ws-none",
      "protocol": "trojan",
      "listen": "0.0.0.0",
      "port": 10006,
      "settings": {
        "clients": [
          {
            "password": "chimera-test-password",
            "email": "test@trojan-ws-none"
          }
        ]
      },
      "streamSettings": {
        "network": "ws",
        "security": "none",
        "wsSettings": {
          "host": "test.chimera.local",
          "path": "/trojan"
        }
      }
    },

    // ===== Non-TLS XHTTP =====
    {
      "tag": "vless-xhttp-none",
      "protocol": "vless",
      "listen": "0.0.0.0",
      "port": 10004,
      "settings": {
        "clients": [
          {
            "id": "3ac9b383-75a1-431c-8184-106c80eb2273",
            "email": "test@vless-xhttp-none",
            "flow": ""
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "none",
        "xhttpSettings": {
          "host": "test.chimera.local",
          "path": "/xhttp",
          "mode": "auto"
        }
      }
    },

    // ===== TLS TCP =====
    {
      "tag": "socks-tcp-tls",
      "protocol": "socks",
      "listen": "0.0.0.0",
      "port": 20000,
      "settings": {
        "auth": "noauth"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "tls",
        "tlsSettings": {
          "alpn": ["http/1.1"],
          "certificates": [
            {
              "certificateFile": "./cert/cert.pem",
              "keyFile": "./cert/key.pem",
              "usage": "encipherment"
            }
          ],
          "minVersion": "1.2",
          "maxVersion": "1.3"
        }
      }
    },
    {
      "tag": "vless-tcp-tls",
      "protocol": "vless",
      "listen": "0.0.0.0",
      "port": 20002,
      "settings": {
        "clients": [
          {
            "id": "3ac9b383-75a1-431c-8184-106c80eb2273",
            "email": "test@vless-tcp-tls",
            "flow": "xtls-rprx-vision"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "tls",
        "tlsSettings": {
          "alpn": ["http/1.1"],
          "certificates": [
            {
              "certificateFile": "./cert/cert.pem",
              "keyFile": "./cert/key.pem",
              "usage": "encipherment"
            }
          ],
          "minVersion": "1.2",
          "maxVersion": "1.3"
        }
      }
    },
    {
      "tag": "trojan-tcp-tls",
      "protocol": "trojan",
      "listen": "0.0.0.0",
      "port": 20005,
      "settings": {
        "clients": [
          {
            "password": "chimera-test-password",
            "email": "test@trojan-tcp-tls"
          }
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "tls",
        "tlsSettings": {
          "alpn": ["http/1.1"],
          "certificates": [
            {
              "certificateFile": "./cert/cert.pem",
              "keyFile": "./cert/key.pem",
              "usage": "encipherment"
            }
          ],
          "minVersion": "1.2",
          "maxVersion": "1.3"
        }
      }
    },
    {
      "tag": "dokodemo-tcp-tls",
      "protocol": "dokodemo-door",
      "listen": "0.0.0.0",
      "port": 20007,
      "settings": {
        "address": "8.8.8.8",
        "port": 53,
        "followRedirect": false
      },
      "streamSettings": {
        "network": "tcp",
        "security": "tls",
        "tlsSettings": {
          "alpn": ["http/1.1"],
          "certificates": [
            {
              "certificateFile": "./cert/cert.pem",
              "keyFile": "./cert/key.pem",
              "usage": "encipherment"
            }
          ],
          "minVersion": "1.2",
          "maxVersion": "1.3"
        }
      }
    },

    // ===== TLS WebSocket =====
    {
      "tag": "socks-ws-tls",
      "protocol": "socks",
      "listen": "0.0.0.0",
      "port": 20001,
      "settings": {
        "auth": "noauth"
      },
      "streamSettings": {
        "network": "ws",
        "security": "tls",
        "tlsSettings": {
          "alpn": ["http/1.1"],
          "certificates": [
            {
              "certificateFile": "./cert/cert.pem",
              "keyFile": "./cert/key.pem",
              "usage": "encipherment"
            }
