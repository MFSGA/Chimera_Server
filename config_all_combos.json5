    },
    {
      "tag": "vless-ws-tls",
      "protocol": "vless",
      "listen": "0.0.0.0",
      "port": 20003,
      "settings": {
        "clients": [
          {
            "id": "3ac9b383-75a1-431c-8184-106c80eb2273",
            "email": "test@vless-ws-tls",
            "flow": ""
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "ws",
        "security": "tls",
        "tlsSettings": {
          "alpn": ["http/1.1"],
          "certificates": [
            {
              "certificateFile": "./cert/cert.pem",
              "keyFile": "./cert/key.pem",
              "usage": "encipherment"
            }
          ],
          "minVersion": "1.2",
          "maxVersion": "1.3"
        },
        "wsSettings": {
          "host": "test.chimera.local",
          "path": "/vless"
        }
      }
    },
    {
      "tag": "trojan-ws-tls",
      "protocol": "trojan",
      "listen": "0.0.0.0",
      "port": 20006,
      "settings": {
        "clients": [
          {
            "password": "chimera-test-password",
            "email": "test@trojan-ws-tls"
          }
        ]
      },
      "streamSettings": {
        "network": "ws",
        "security": "tls",
        "tlsSettings": {
          "alpn": ["http/1.1"],
          "certificates": [
            {
              "certificateFile": "./cert/cert.pem",
              "keyFile": "./cert/key.pem",
              "usage": "encipherment"
            }
          ],
          "minVersion": "1.2",
