        "xhttpSettings": {
          "host": "test.chimera.local",
          "path": "/xhttp",
          "mode": "auto"
        }
      }
    },

    // ===== Reality =====
    {
      "tag": "vless-tcp-reality",
      "protocol": "vless",
      "listen": "0.0.0.0",
      "port": 30000,
      "settings": {
        "clients": [
          {
            "id": "3ac9b383-75a1-431c-8184-106c80eb2273",
            "email": "test@vless-tcp-reality",
            "flow": "xtls-rprx-vision"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "dest": "addons.mozilla.org:443",
          "serverNames": ["addons.mozilla.org"],
          "privateKey": "wHyg5tTbJM1gQsEVmd5Tp6US24dTuz8miowGDVaP6Iw",
          "shortIds": ["4ac97aaf8b9b0356"],
          "maxTimeDiff": 0
        }
      }
    },
    {
      "tag": "vless-xhttp-reality",
      "protocol": "vless",
      "listen": "0.0.0.0",
      "port": 30001,
      "settings": {
        "clients": [
          {
            "id": "3ac9b383-75a1-431c-8184-106c80eb2273",
            "email": "test@vless-xhttp-reality",
            "flow": ""
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "reality",
        "realitySettings": {
          "dest": "addons.mozilla.org:443",
          "serverNames": ["addons.mozilla.org"],
          "privateKey": "wHyg5tTbJM1gQsEVmd5Tp6US24dTuz8miowGDVaP6Iw",
          "shortIds": ["4ac97aaf8b9b0356"],
          "maxTimeDiff": 0
        },
        "xhttpSettings": {
          "host": "test.chimera.local",
          "path": "/reality-xhttp",
          "mode": "auto"
        }
      }
    },

    // ===== Hysteria2 (QUIC + mandatory TLS) =====
    {
      "tag": "hysteria2-quic",
      "protocol": "hysteria2",
      "listen": "0.0.0.0",
      "port": 40000,
      "settings": {
        "clients": [
          {
            "id": "chimera-hy2-user",
            "email": "test@hysteria2"
          }
        ]
      },
      "streamSettings": {
        "network": "quic",
        "security": "tls",
        "tlsSettings": {
          "alpn": ["h3"],
          "certificates": [
            {
              "certificateFile": "./cert/cert.pem",
              "keyFile": "./cert/key.pem",
              "usage": "encipherment"
            }
          ]
        },
        "hysteriaSettings": {
          "version": 2,
          "up": "100mbps",
          "down": "200mbps",
          "ignoreClientBandwidth": false
        }
      }
    }
  ]
}
