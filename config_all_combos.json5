    // ===== TLS XHTTP =====
    {
      "tag": "vless-xhttp-tls",
      "protocol": "vless",
      "listen": "0.0.0.0",
      "port": 20004,
      "settings": {
        "clients": [
          {
            "id": "3ac9b383-75a1-431c-8184-106c80eb2273",
            "email": "test@vless-xhttp-tls",
            "flow": ""
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "tls",
        "tlsSettings": {
          "alpn": ["http/1.1"],
