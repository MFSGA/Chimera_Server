{
  "inbounds": [
    {
      "tag": "vless-ws-tls",
      "listen": "127.0.0.1",
      "port": 11006,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "3ac9b383-75a1-431c-8184-106c80eb2273",
            "email": "vless-ws-tls@example.com"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "ws",
        "security": "tls",
        "wsSettings": {
          "host": "example.com",
          "path": "/ws-tls",
          "headers": {
            "Host": "edge.example.com"
          }
        },
        "tlsSettings": {
          "serverName": "example.com",
          "certificates": [
            {
              "certificateFile": "cert/server.crt",
              "keyFile": "cert/server.key"
            }
          ]
        }
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "protocol": "freedom"
    }
  ]
}
